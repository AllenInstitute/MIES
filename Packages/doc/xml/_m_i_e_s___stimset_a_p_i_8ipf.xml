<parameternamelist>
<parametername>var</parametername>
</parameternamelist>
<parameterdescription>
<para>[optional, one of <computeroutput>var</computeroutput>/<computeroutput>str</computeroutput> must be present] numeric parameter to set </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>str</parametername>
</parameternamelist>
<parameterdescription>
<para>[optional, one of <computeroutput>var</computeroutput>/<computeroutput>str</computeroutput> must be present] string parameter to set</para>
